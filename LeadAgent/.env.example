# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://leadagent:leadagent_dev@localhost:5433/leadagent

# ── Embeddings — Gemini (primary) ─────────────────────────────────────────────
GEMINI_API_KEY=AIza...
# Must match the vector() dimension in migration 0001. Changing this requires
# re-embedding all chunks AND a schema migration to alter the column dimension.
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=100

# ── Embeddings — OpenAI (optional, not used in v1) ────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Crawler ───────────────────────────────────────────────────────────────────
CRAWLER_USER_AGENT=LeadAgent-Crawler/1.0 (+https://yourcompany.com/bot)
CRAWLER_DEFAULT_DEPTH=2
CRAWLER_MAX_PAGES=200
CRAWLER_REQUEST_TIMEOUT_SECONDS=10
CRAWLER_CRAWL_DELAY_SECONDS=0.5

# ── Chunking ──────────────────────────────────────────────────────────────────
# 256/32 recommended for small-text sites (< 5k chars per page).
# 512/64 is better for long-form documentation / blog content.
CHUNK_TOKENS=256
CHUNK_OVERLAP_TOKENS=32

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_K=30
RETRIEVAL_RRF_K=60
RETRIEVAL_MIN_COSINE_SCORE=0.0

# ── Agent loop (M2+) ──────────────────────────────────────────────────────────
# Gemini model for tool-calling loop. gemini-2.0-flash is fast and supports function calling.
AGENT_MODEL=gemini-2.0-flash
AGENT_MAX_TOOL_ROUNDS=8
# Name shown in the system prompt
COMPANY_NAME=MAC TechWorks & Consulting LLC

# ── Grounding threshold (M4+) ─────────────────────────────────────────────────
# Minimum cosine score for a search_knowledge result to be considered grounded.
# 0.0 = disabled (only grounded=false when count=0).
# Tune upward (e.g. 0.45) after running evals to reduce hallucination on low-confidence results.
GROUNDING_COSINE_THRESHOLD=0.0
# Model used for LLM-as-judge in make eval
EVAL_JUDGE_MODEL=gemini-2.0-flash

ENV=dev
LOG_LEVEL=INFO
