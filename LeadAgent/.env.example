# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://leadagent:leadagent_dev@localhost:5433/leadagent

# ── Embeddings — Gemini (primary) ─────────────────────────────────────────────
GEMINI_API_KEY=AIza...
# Must match the vector() dimension in migration 0001. Changing this requires
# re-embedding all chunks AND a schema migration to alter the column dimension.
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=100

# ── Embeddings — OpenAI (optional, not used in v1) ────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Crawler ───────────────────────────────────────────────────────────────────
CRAWLER_USER_AGENT=LeadAgent-Crawler/1.0 (+https://yourcompany.com/bot)
CRAWLER_DEFAULT_DEPTH=2
CRAWLER_MAX_PAGES=200
CRAWLER_REQUEST_TIMEOUT_SECONDS=10
CRAWLER_CRAWL_DELAY_SECONDS=0.5

# ── Chunking ──────────────────────────────────────────────────────────────────
# 256/32 recommended for small-text sites (< 5k chars per page).
# 512/64 is better for long-form documentation / blog content.
CHUNK_TOKENS=256
CHUNK_OVERLAP_TOKENS=32

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_K=30
RETRIEVAL_RRF_K=60
RETRIEVAL_MIN_COSINE_SCORE=0.0

# ── Agent loop (M2+) ──────────────────────────────────────────────────────────
# DeepSeek model (OpenAI-compatible) for the tool-calling loop.
DEEPSEEK_API_KEY=sk-...
AGENT_MODEL=deepseek-chat
AGENT_MAX_TOOL_ROUNDS=8
# Name shown in the system prompt
COMPANY_NAME=MAC TechWorks & Consulting LLC

# ── Grounding threshold (M4+) ─────────────────────────────────────────────────
# Minimum cosine score for a search_knowledge result to be considered grounded.
# 0.0 = disabled (only grounded=false when count=0).
# Tune upward (e.g. 0.45) after running evals to reduce hallucination on low-confidence results.
GROUNDING_COSINE_THRESHOLD=0.0
# Model used for LLM-as-judge in make eval
EVAL_JUDGE_MODEL=deepseek-chat

# ── Calendar integration (M5) ────────────────────────────────────────────────
# "mock" (default) or "google"
CALENDAR_ADAPTER=mock
# Google Calendar — only needed when CALENDAR_ADAPTER=google
# GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account.json
# GOOGLE_CALENDAR_ID=primary
# GOOGLE_SLOT_DURATION_MINUTES=30

# ── CRM integration (M6) ────────────────────────────────────────────────────
# "mock" (default) or "sheets" (Google Sheets)
CRM_ADAPTER=mock
# Google Sheets — only needed when CRM_ADAPTER=sheets
# Share the sheet with your service account email (Editor role).
# GOOGLE_SHEETS_SPREADSHEET_ID=1abc...xyz
# GOOGLE_SHEETS_SHEET_NAME=Leads

# ── API (M6) ─────────────────────────────────────────────────────────────────
# Admin endpoints (GET /admin/traces) require this key via X-Admin-Key header.
# Use a strong random string (>= 16 chars). Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=change-me-to-a-real-secret
# Comma-separated allowed origins for CORS. "*" allows all (dev only).
# Production: set to the actual domain(s) embedding the widget.
ALLOWED_ORIGINS=*
# Abuse protection
RATE_LIMIT_RPM=30
ADMIN_RATE_LIMIT_RPM=10
MAX_MESSAGE_LENGTH=2000
MAX_CONVERSATION_TURNS=50
SESSION_TTL_SECONDS=3600
# Per-conversation token budget and daily ceiling (all IPs combined)
CONVERSATION_TOKEN_BUDGET=50000
DAILY_TOKEN_CEILING=500000

# ── Security ─────────────────────────────────────────────────────────────────
# Set to "true" in production behind TLS-terminating proxy
FORCE_HTTPS=false
HSTS_MAX_AGE=31536000
# Comma-separated trusted proxy IPs (for X-Forwarded-For parsing)
# TRUSTED_PROXY_IPS=10.0.0.1,172.16.0.1

# ── Email (booking confirmation) ─────────────────────────────────────────────
# "none" (default) or "smtp"
EMAIL_ADAPTER=none
# SMTP — only needed when EMAIL_ADAPTER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_NAME=LeadAgent

ENV=dev
LOG_LEVEL=INFO
